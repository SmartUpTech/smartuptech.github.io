---
import type { App } from '../data/apps';

interface Props {
	app: App;
	reverse?: boolean;
}

const { app, reverse = false } = Astro.props;
---

<section class="section-spacing overflow-hidden">
	<div class="max-w-[1400px] mx-auto px-6 md:px-12">
		<div class={`flex flex-col ${reverse ? 'md:flex-row-reverse' : 'md:flex-row'} items-center gap-16 md:gap-32`}>
			<div class="flex-1 space-y-8">
				<div class="space-y-4">
					<span class="text-sm font-bold tracking-widest uppercase" style={`color: ${app.themeColor}`}>
						{app.category}
					</span>
					<h2 class="text-5xl md:text-7xl">{app.name}</h2>
					<p class="text-xl md:text-2xl font-medium text-black/80">{app.tagline}</p>
				</div>

				<p class="max-w-xl">{app.description}</p>

				<ul class="space-y-4 pt-4">
					{app.features.map(feature => (
						<li class="flex items-center gap-3 text-gray-600">
							<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style={`color: ${app.themeColor}`}><path d="M20 6 9 17l-5-5"/></svg>
							{feature}
						</li>
					))}
				</ul>

				<div class="pt-8">
					<a
						href={app.playStoreUrl}
						class="inline-flex items-center gap-2 font-semibold text-lg hover:gap-4 transition-all duration-300"
						style={`color: ${app.themeColor}`}
					>
						Get on Play Store
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
					</a>
				</div>
			</div>

			<div class="flex-1 w-full">
				<div
					class="aspect-[4/5] md:aspect-square rounded-[3rem] bg-gray-50 flex items-center justify-center p-12 relative overflow-hidden group"
				>
					<!-- Abstract product representation since we don't have screenshots -->
					<div
						class="w-2/3 h-4/5 rounded-[2rem] shadow-2xl transition-transform duration-700 group-hover:scale-105"
						style={`background: linear-gradient(135deg, ${app.themeColor}10 0%, ${app.themeColor}20 100%); border: 1px solid ${app.themeColor}30;`}
					>
						<div class="absolute inset-0 flex items-center justify-center text-8xl opacity-20 filter grayscale">
							{app.name.charAt(0)}
						</div>
					</div>

					<!-- Decorative floaters -->
					<div
						class="absolute top-1/4 right-10 w-24 h-24 rounded-3xl blur-2xl opacity-40 animate-pulse"
						style={`background-color: ${app.themeColor}`}
					></div>
				</div>
			</div>
		</div>
	</div>
</section>
