---
import type { FAQ } from '../data/apps';

interface Props {
	faqs: FAQ[];
}

const { faqs } = Astro.props;
---

<div class="space-y-6 max-w-3xl mx-auto">
	{faqs.map((faq) => (
		<div class="p-8 bg-gray-50/50 rounded-3xl border border-transparent hover:border-gray-100 transition-all">
			<h4 class="text-lg font-bold mb-4">{faq.question}</h4>
			<p class="text-gray-500 leading-relaxed">{faq.answer}</p>
		</div>
	))}
</div>
