---
import { apps } from '../data/apps';
const currentYear = new Date().getFullYear();
---

<footer class="py-24 border-t border-gray-100 bg-white">
	<div class="max-w-[1400px] mx-auto px-6 md:px-12">
		<div class="grid grid-cols-1 md:grid-cols-4 gap-12">
			<div class="col-span-1 md:col-span-2">
				<a href="/" class="text-xl font-bold tracking-tighter">
					SmartUp<span class="font-normal text-gray-400 ml-1">Tech</span>
				</a>
				<p class="mt-4 max-w-sm text-gray-500">
					Building premium utility tools for everyday life.
					Simple, thoughtful, and private apps for millions of users worldwide.
				</p>
			</div>

			<div class="flex flex-col gap-4">
				<span class="font-semibold text-black uppercase text-xs tracking-widest">Android Apps</span>
				{apps.map(app => (
					<a href={`/apps/${app.id}`} class="text-sm text-gray-500 hover:text-black transition-colors">{app.name}</a>
				))}
			</div>

			<div class="flex flex-col gap-4">
				<span class="font-semibold text-black uppercase text-xs tracking-widest">Links</span>
				<a href="/apps" class="text-sm text-gray-500 hover:text-black transition-colors">All Apps</a>
				<a href="https://play.google.com/store/apps/dev?id=6614685995890456247" target="_blank" class="text-sm text-gray-500 hover:text-black transition-colors">Developer Profile</a>
				<a href="#" class="text-sm text-gray-500 hover:text-black transition-colors">Privacy Policy</a>
				<a href="#" class="text-sm text-gray-500 hover:text-black transition-colors">Support</a>
			</div>
		</div>

		<div class="mt-24 pt-8 border-t border-gray-50 flex flex-col md:flex-row justify-between items-center text-xs text-gray-400 gap-4">
			<p>&copy; {currentYear} SmartUp Tech. All rights reserved.</p>
			<div class="flex gap-8">
				<a href="https://play.google.com/store/apps/dev?id=6614685995890456247" target="_blank" class="hover:text-black transition-colors underline underline-offset-4">More Apps on Google Play</a>
			</div>
		</div>
	</div>
</footer>
