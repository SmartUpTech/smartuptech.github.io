---
const currentYear = new Date().getFullYear();
---

<footer class="py-24 border-t border-gray-100">
	<div class="max-w-[1400px] mx-auto px-6 md:px-12">
		<div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-12">
			<div>
				<a href="/" class="text-xl font-bold tracking-tighter">
					SmartUp<span class="font-normal text-gray-400 ml-1">Tech</span>
				</a>
				<p class="mt-4 max-w-xs text-sm">
					Building premium utility tools for everyday life.
					Simple, thoughtful, and private.
				</p>
			</div>

			<div class="flex gap-12 text-sm">
				<div class="flex flex-col gap-4">
					<span class="font-semibold text-black">Products</span>
					<a href="#" class="text-gray-500 hover:text-black">Vedic Panchang</a>
					<a href="#" class="text-gray-500 hover:text-black">Today</a>
					<a href="#" class="text-gray-500 hover:text-black">Unit Converter</a>
				</div>
				<div class="flex flex-col gap-4">
					<span class="font-semibold text-black">Company</span>
					<a href="#" class="text-gray-500 hover:text-black">Privacy</a>
					<a href="#" class="text-gray-500 hover:text-black">Support</a>
					<a href="#" class="text-gray-500 hover:text-black">Twitter</a>
				</div>
			</div>
		</div>

		<div class="mt-24 flex flex-col md:flex-row justify-between text-xs text-gray-400 gap-4">
			<p>&copy; {currentYear} SmartUp Tech. All rights reserved.</p>
			<div class="flex gap-8">
				<a href="#" class="hover:text-black">Terms</a>
				<a href="#" class="hover:text-black">Privacy</a>
				<a href="#" class="hover:text-black">Legal</a>
			</div>
		</div>
	</div>
</footer>
