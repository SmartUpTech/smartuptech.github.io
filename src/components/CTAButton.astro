---
interface Props {
	href: string;
	variant?: 'primary' | 'secondary' | 'link';
	class?: string;
	target?: string;
	rel?: string;
	[key: string]: any;
}

const { href, variant = 'primary', class: className, target, rel, ...rest } = Astro.props;

const baseStyles = "inline-flex items-center justify-center transition-all duration-300 font-medium";
const variants = {
	primary: "bg-black text-white hover:bg-gray-800 px-8 py-4 rounded-full text-lg",
	secondary: "bg-gray-100 text-black hover:bg-gray-200 px-8 py-4 rounded-full text-lg",
	link: "text-black hover:opacity-70 p-0 text-lg gap-2"
};
---

<a
	href={href}
	class:list={[baseStyles, variants[variant], className]}
	target={target}
	rel={rel || (target === '_blank' ? 'noopener noreferrer' : undefined)}
	{...rest}
>
	<slot />
	{variant === 'link' && (
		<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
	)}
</a>
