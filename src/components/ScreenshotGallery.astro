---
interface Props {
	themeColor: string;
}

const { themeColor } = Astro.props;
---

<div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-8">
	{[1, 2, 3, 4].map((i) => (
		<div
			class="aspect-[9/16] rounded-[2rem] bg-gray-50 border border-gray-100 flex items-center justify-center relative overflow-hidden group shadow-sm hover:shadow-xl transition-all"
		>
			<div
				class="absolute inset-0 opacity-0 group-hover:opacity-10 transition-opacity"
				style={`background-color: ${themeColor}`}
			></div>
			<span class="text-xs font-bold text-gray-300 uppercase tracking-widest">Screenshot {i}</span>
		</div>
	))}
</div>
