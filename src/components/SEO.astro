---
import type { App } from '../data/apps';

interface Props {
	app?: App;
	title?: string;
	description?: string;
}

const { app, title, description } = Astro.props;

const seoTitle = app ? `${app.name} - ${app.tagline} | SmartUp Tech` : (title ? `${title} | SmartUp Tech` : "SmartUp Tech");
const seoDescription = app ? app.shortDescription : (description || "Premium Android Utility Apps by SmartUp Tech");
const canonicalURL = new URL(Astro.url.pathname, Astro.site || "https://smartuptech.github.io");

// Structured Data for App
const jsonLd = app ? {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": app.name,
  "operatingSystem": "ANDROID",
  "applicationCategory": app.category,
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "description": app.longDescription,
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.5",
    "ratingCount": "1000"
  }
} : null;
---

<!-- Primary Meta Tags -->
<title>{seoTitle}</title>
<meta name="title" content={seoTitle} />
<meta name="description" content={seoDescription} />
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={seoTitle} />
<meta property="og:description" content={seoDescription} />
<meta property="og:image" content="/og-image.png" />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={seoTitle} />
<meta property="twitter:description" content={seoDescription} />
<meta property="twitter:image" content="/og-image.png" />

{jsonLd && (
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
)}
