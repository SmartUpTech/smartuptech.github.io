---
import type { App } from '../data/apps';

interface Props {
	app: App;
}

const { app } = Astro.props;
---

<div class="app-card" style={`--accent: ${app.themeColor}`}>
	<div class="app-icon" style={`background-color: ${app.themeColor}15; color: ${app.themeColor}`}>
		<span class="category">{app.category}</span>
	</div>
	<div class="content">
		<h3>{app.name}</h3>
		<p class="tagline">{app.tagline}</p>
		<p class="description">{app.description}</p>
		<a href={app.playStoreUrl} class="learn-more">
			Learn more
			<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
		</a>
	</div>
</div>

<style>
	.app-card {
		padding: 48px;
		background: #ffffff;
		border-radius: 24px;
		transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
		display: flex;
		flex-direction: column;
		height: 100%;
		border: 1px solid #f3f4f6;
	}

	.app-card:hover {
		transform: translateY(-8px);
		box-shadow: 0 20px 40px rgba(0,0,0,0.04);
		border-color: var(--accent);
	}

	.app-icon {
		width: fit-content;
		padding: 6px 12px;
		border-radius: 8px;
		margin-bottom: 24px;
	}

	.category {
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	h3 {
		font-size: 1.75rem;
		margin-bottom: 8px;
		color: #111827;
	}

	.tagline {
		font-weight: 600;
		color: var(--accent);
		margin-bottom: 16px;
		font-size: 1rem;
	}

	.description {
		margin-bottom: 32px;
		flex-grow: 1;
	}

	.learn-more {
		display: inline-flex;
		align-items: center;
		gap: 4px;
		color: #111827;
		text-decoration: none;
		font-weight: 600;
		font-size: 0.95rem;
		transition: gap 0.2s ease;
	}

	.learn-more:hover {
		gap: 8px;
	}

	@media (max-width: 768px) {
		.app-card {
			padding: 32px;
		}
	}
</style>
