---
import type { App } from '../data/apps';

interface Props {
	app: App;
}

const { app } = Astro.props;
---

<div class="group relative flex flex-col bg-gray-50/50 rounded-[2.5rem] p-8 md:p-12 hover:bg-white transition-all duration-500 hover:shadow-2xl border border-transparent hover:border-gray-100">
	<div class="flex items-start justify-between mb-8">
		<img
			src={app.icon}
			alt={`${app.name} - ${app.tagline}`}
			loading="lazy"
			decoding="async"
			class="w-20 h-20 rounded-3xl shadow-sm object-cover"
			style={`border: 1px solid ${app.themeColor}20`}
		/>
		<span
			class="text-[10px] font-bold tracking-[0.2em] uppercase px-3 py-1 rounded-full bg-white border"
			style={`color: ${app.themeColor}; border-color: ${app.themeColor}30`}
		>
			{app.category}
		</span>
	</div>

	<div class="flex-grow">
		<h3 class="text-2xl font-bold mb-2 group-hover:text-black transition-colors">{app.name}</h3>
		<p class="text-sm font-semibold mb-4" style={`color: ${app.themeColor}`}>{app.tagline}</p>
		<p class="text-gray-500 text-sm leading-relaxed mb-8 line-clamp-3">
			{app.shortDescription}
		</p>

		<ul class="space-y-2 mb-8">
			{app.features.slice(0, 3).map(feature => (
				<li class="flex items-center gap-2 text-xs text-gray-400">
					<div class="w-1 h-1 rounded-full" style={`background-color: ${app.themeColor}`}></div>
					{feature}
				</li>
			))}
		</ul>
	</div>

	<div class="flex items-center gap-4 pt-4">
		<a
			href={`/apps/${app.id}`}
			class="flex-1 text-center py-3 rounded-full text-sm font-bold bg-white border border-gray-200 hover:border-black transition-all"
		>
			Details
		</a>
		<a
			href={app.playStoreUrl}
			target="_blank"
			class="w-12 h-12 flex items-center justify-center rounded-full bg-black text-white hover:bg-gray-800 transition-all shadow-lg"
			aria-label="Download on Google Play"
		>
			<svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
				<path d="M3,20.5V3.5C3,2.91 3.34,2.39 3.84,2.15L13.69,12L3.84,21.85C3.34,21.61 3,21.09 3,20.5M16.81,15.12L18.66,14.05C21.08,12.65 21.08,11.35 18.66,9.95L16.81,8.88L14.4,11.29L16.81,15.12M4.6,2.09L13.97,11.46L16.08,9.35L4.87,2.92C4.78,2.87 4.69,2.83 4.6,2.79C4.46,2.74 4.34,2.71 4.24,2.71C4.06,2.71 3.94,2.8 3.94,3C3.94,3 4.22,2.47 4.6,2.09M3.94,21C3.94,21.2 4.06,21.29 4.24,21.29C4.34,21.29 4.46,21.26 4.6,21.21C4.69,21.17 4.78,21.13 4.87,21.08L16.08,14.65L13.97,12.54L4.6,21.91C4.22,21.53 3.94,21 3.94,21Z" />
			</svg>
		</a>
	</div>
</div>
