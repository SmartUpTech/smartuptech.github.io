---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import SEO from '../../components/SEO.astro';
import { articles } from '../../data/articles';
import { apps } from '../../data/apps';

export async function getStaticPaths() {
	const paths = [];

	// 1. Article Detail Pages: /articles/[appId]/[slug]
	articles.forEach((article) => {
		paths.push({
			params: { path: `${article.appId}/${article.slug}` },
			props: { type: 'article', article },
		});
	});

	// 2. App-Specific Article Hubs: /articles/[appId]
	apps.forEach((app) => {
		const appArticles = articles.filter((a) => a.appId === app.id);
		paths.push({
			params: { path: app.id },
			props: { type: 'app-hub', app, appArticles },
		});
	});

	return paths;
}

const { path } = Astro.params;
const { type, article, app, appArticles } = Astro.props;
---

{type === 'article' ? (
	<Layout title={article.title}>
		<SEO slot="head" article={article} />
		<Navbar />
		<main class="pt-24">
			<header class="py-16 md:py-24">
				<div class="max-w-[1000px] mx-auto px-6 md:px-12 text-center mb-16">
					<div class="flex items-center justify-center gap-4 mb-8">
						<span class="px-4 py-2 bg-gray-50 text-[10px] font-bold tracking-widest uppercase rounded-full text-gray-500">
							{article.category}
						</span>
						<span class="text-gray-300">•</span>
						<time class="text-xs font-bold tracking-widest uppercase text-gray-400">
							{new Date(article.publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
						</time>
					</div>
					<h1 class="text-4xl md:text-6xl leading-[1.1] mb-8">{article.title}</h1>
					<p class="text-xl md:text-2xl text-gray-500 max-w-2xl mx-auto leading-relaxed">
						{article.excerpt}
					</p>
				</div>

				<div class="max-w-[1400px] mx-auto px-6 md:px-12">
					<div class="aspect-[21/9] w-full rounded-[2.5rem] md:rounded-[4rem] overflow-hidden bg-gray-100 shadow-2xl">
						<img src={article.coverImage} alt={article.title} class="w-full h-full object-cover" />
					</div>
				</div>
			</header>

			<section class="py-24">
				<div class="max-w-[1400px] mx-auto px-6 md:px-12">
					<div class="flex flex-col lg:flex-row gap-24">
						<div class="flex-1 max-w-[800px] mx-auto lg:mx-0">
							<div class="prose prose-lg prose-black max-w-none prose-headings:font-bold prose-headings:tracking-tight prose-p:text-gray-600 prose-p:leading-relaxed prose-li:text-gray-600">
								<div set:html={article.content} />
							</div>

							<!-- App CTA -->
							{(() => {
								const parentApp = apps.find(a => a.id === article.appId);
								return parentApp ? (
									<div class="mt-24 p-12 md:p-16 rounded-[3rem] bg-gray-50 border border-gray-100 flex flex-col md:flex-row items-center gap-10">
										<img src={parentApp.icon} alt={parentApp.name} class="w-32 h-32 rounded-[2rem] shadow-xl" />
										<div class="flex-1 text-center md:text-left">
											<h3 class="text-2xl font-bold mb-4">Master {parentApp.name}</h3>
											<p class="text-gray-500 mb-8 leading-relaxed">
												Experience the best of {parentApp.category.toLowerCase()} with our premium Android application.
											</p>
											<div class="flex flex-wrap justify-center md:justify-start gap-4">
												<a href={`/apps/${parentApp.id}`} class="px-8 py-4 bg-black text-white rounded-full font-bold text-sm hover:bg-gray-800 transition-all shadow-lg">Details</a>
												<a href={parentApp.playStoreUrl} target="_blank" rel="noopener noreferrer" data-track-playstore data-app-name={parentApp.name} class="px-8 py-4 bg-white border border-gray-200 rounded-full font-bold text-sm hover:border-black transition-all">Get on Play Store</a>
											</div>
										</div>
									</div>
								) : null;
							})()}
						</div>

						<aside class="w-full lg:w-[350px] space-y-16">
							{(() => {
								const parentApp = apps.find(a => a.id === article.appId);
								return parentApp ? (
									<div class="space-y-8">
										<h4 class="text-xs font-bold uppercase tracking-widest text-gray-400">More {parentApp.topicName} Articles</h4>
										<div class="space-y-8">
											{articles.filter(a => a.appId === article.appId && a.slug !== article.slug).slice(0, 3).map(rel => (
												<a href={`/articles/${rel.appId}/${rel.slug}`} class="group block space-y-4">
													<div class="aspect-video rounded-3xl overflow-hidden bg-gray-100">
														<img src={rel.coverImage} alt={rel.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
													</div>
													<h5 class="font-bold leading-snug group-hover:text-black transition-colors">{rel.title}</h5>
												</a>
											))}
										</div>
										<a href={`/articles/${parentApp.id}`} class="inline-block font-bold text-sm border-b-2 border-black pb-1">View all {parentApp.topicName} guides</a>
									</div>
								) : null;
							})()}

							<div class="space-y-8 pt-8 border-t border-gray-100">
								<h4 class="text-xs font-bold uppercase tracking-widest text-gray-400">Explore SmartUp Apps</h4>
								<div class="grid grid-cols-2 gap-4">
									{apps.filter(a => a.id !== article.appId).slice(0, 4).map(otherApp => (
										<a href={`/apps/${otherApp.id}`} class="group block space-y-2">
											<img src={otherApp.icon} alt={otherApp.name} class="w-12 h-12 rounded-xl shadow-sm group-hover:shadow-md transition-all" />
											<p class="text-[10px] font-bold uppercase tracking-wider">{otherApp.name}</p>
										</a>
									))}
								</div>
							</div>
						</aside>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</Layout>
) : (
	<Layout title={`${app.topicName} Articles`}>
		<SEO slot="head" title={`${app.topicName} Articles | SmartUp Tech`} description={`Explore educational guides and articles about ${app.topicName.toLowerCase()}.`} />
		<Navbar />
		<main class="pt-24">
			<section class="py-16 md:py-24 bg-gray-50/30">
				<div class="max-w-[1400px] mx-auto px-6 md:px-12 text-center">
					<span class="text-xs font-bold tracking-widest uppercase text-gray-400 mb-4 block">{app.topicName}</span>
					<h1 class="mb-8">{app.topicName} <span class="text-gray-400">Articles.</span></h1>
					<p class="max-w-2xl mx-auto text-xl md:text-2xl text-gray-500">
						Deep dive into the features and concepts behind {app.topicName.toLowerCase()}.
					</p>
				</div>
			</section>

			<section class="py-24">
				<div class="max-w-[1400px] mx-auto px-6 md:px-12">
					<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
						{appArticles.map(art => (
							<article class="group flex flex-col h-full bg-white rounded-[2.5rem] overflow-hidden border border-gray-100 hover:shadow-2xl transition-all duration-500">
								<div class="aspect-[16/9] overflow-hidden bg-gray-100 relative">
									<img src={art.coverImage} alt={art.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
								</div>
								<div class="p-8 md:p-10 flex flex-col flex-grow">
									<h2 class="text-2xl font-bold mb-4 group-hover:text-black transition-colors leading-tight">
										<a href={`/articles/${art.appId}/${art.slug}`}>{art.title}</a>
									</h2>
									<p class="text-gray-500 text-sm leading-relaxed mb-8 flex-grow">{art.excerpt}</p>
									<a href={`/articles/${art.appId}/${art.slug}`} class="inline-flex items-center gap-2 font-bold text-sm group-hover:gap-4 transition-all">Read More</a>
								</div>
							</article>
						))}
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</Layout>
)}

<style is:global>
	@reference "../../styles/global.css";
	.prose h2 { @apply text-3xl mt-16 mb-8; }
	.prose h3 { @apply text-2xl mt-12 mb-6; }
	.prose p { @apply mb-8; }
	.prose ul { @apply mb-8 list-disc pl-6; }
	.prose li { @apply mb-3; }
	.prose table { @apply w-full border-collapse mb-12; }
	.prose th { @apply text-left py-4 px-4 bg-gray-50 border-b border-gray-100 font-bold text-sm uppercase tracking-wider; }
	.prose td { @apply py-4 px-4 border-b border-gray-50 text-sm; }
	.prose strong { @apply text-black font-bold; }
</style>
