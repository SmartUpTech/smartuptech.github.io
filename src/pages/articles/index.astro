---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import SEO from '../../components/SEO.astro';
import { articles } from '../../data/articles';
import { apps } from '../../data/apps';

const title = "Articles & Guides | SmartUp Tech";
const description = "Explore educational guides, tips, and deep dives across our suite of utility and cultural apps.";
---

<Layout title="Articles">
	<SEO slot="head" title={title} description={description} />
	<Navbar />

	<main class="pt-24">
		<!-- Hero -->
		<section class="py-16 md:py-24 bg-gray-50/30">
			<div class="max-w-[1400px] mx-auto px-6 md:px-12 text-center">
				<h1 class="mb-8">Everyday <span class="text-gray-400">Articles.</span></h1>
				<p class="max-w-2xl mx-auto text-xl md:text-2xl text-gray-500">
					Educational guides and insights across all our applications.
				</p>
			</div>
		</section>

		<!-- Apps Categories (Horizontal Scroll on Mobile) -->
		<section class="py-12 border-b border-gray-100 sticky top-20 bg-white/80 backdrop-blur-md z-40">
			<div class="max-w-[1400px] mx-auto px-6 md:px-12">
				<div class="flex items-center gap-4 overflow-x-auto no-scrollbar pb-2">
					<span class="text-xs font-bold uppercase tracking-widest text-gray-400 whitespace-nowrap mr-4">Filter by App:</span>
					{apps.map(app => (
						<a
							href={`/articles/${app.id}`}
							class="px-6 py-2 rounded-full border border-gray-100 text-sm font-medium hover:border-black transition-all whitespace-nowrap"
						>
							{app.topicName}
						</a>
					))}
				</div>
			</div>
		</section>

		<!-- All Articles Grid -->
		<section class="py-24">
			<div class="max-w-[1400px] mx-auto px-6 md:px-12">
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
					{articles.map(article => (
						<article class="group flex flex-col h-full bg-white rounded-[2.5rem] overflow-hidden border border-gray-100 hover:shadow-2xl transition-all duration-500">
							<div class="aspect-[16/9] overflow-hidden bg-gray-100 relative">
								<img src={article.coverImage} alt={article.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
								<div class="absolute top-6 left-6">
									<span class="px-4 py-2 bg-white/90 backdrop-blur text-[10px] font-bold tracking-widest uppercase rounded-full">
										{apps.find(a => a.id === article.appId)?.topicName || article.category}
									</span>
								</div>
							</div>
							<div class="p-8 md:p-10 flex flex-col flex-grow">
								<time class="text-xs text-gray-400 mb-4 block font-medium uppercase tracking-widest">
									{new Date(article.publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
								</time>
								<h2 class="text-2xl font-bold mb-4 group-hover:text-black transition-colors leading-tight">
									<a href={`/articles/${article.appId}/${article.slug}`}>{article.title}</a>
								</h2>
								<p class="text-gray-500 text-sm leading-relaxed mb-8 flex-grow">{article.excerpt}</p>
								<a href={`/articles/${article.appId}/${article.slug}`} class="inline-flex items-center gap-2 font-bold text-sm group-hover:gap-4 transition-all">
									Read More
									<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
								</a>
							</div>
						</article>
					))}
				</div>
			</div>
		</section>
	</main>
	<Footer />
</Layout>
