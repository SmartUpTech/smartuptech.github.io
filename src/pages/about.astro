---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import CTAButton from '../components/CTAButton.astro';
import { apps } from '../data/apps';

const expertise = [
	{
		title: "Enterprise Applications",
		description: "Design and development of business-critical applications tailored for operational excellence."
	},
	{
		title: "Workflow Automation",
		description: "Streamlining digital workflows and approval processes to drive organizational efficiency."
	},
	{
		title: "Mobile Applications",
		description: "High-performance Android applications serving millions of users across diverse domains."
	},
	{
		title: "System Integration",
		description: "Seamlessly connecting platforms, services, and legacy business systems into a cohesive ecosystem."
	},
	{
		title: "Architecture & Design",
		description: "Building scalable, maintainable, and cloud-ready solutions using modern engineering principles."
	},
	{
		title: "Product Development",
		description: "End-to-end lifecycle management from conceptualization to deployment and iterative enhancement."
	}
];

const values = [
	{
		title: "Simplicity",
		description: "We build solutions that are easy to understand, navigate, and maintain, reducing technical debt and cognitive load."
	},
	{
		title: "Reliability",
		description: "Software should work consistently and predictably. We prioritize stability and accuracy in every line of code."
	},
	{
		title: "Scalability",
		description: "Our architectures are designed to grow alongside your business needs, handling increased load without compromise."
	},
	{
		title: "Long-Term Thinking",
		description: "We focus on sustainable performance and accurate data, ensuring our apps remain trusted tools for years to come."
	}
];
---

<Layout title="About SmartUp Tech | Enterprise Software & Mobile Applications">
	<SEO
		slot="head"
		title="About SmartUp Tech | Enterprise Software & Mobile Applications"
		description="Learn about SmartUp Tech, our expertise in enterprise software, workflow automation, and our commitment to building reliable Android applications."
	/>
	<Navbar />

	<main class="pt-20">
		<!-- Hero Section -->
		<section class="section-spacing">
			<div class="max-w-[1000px] mx-auto px-6 text-center">
				<h1 class="mb-8">Building Reliable Software <br /><span class="text-gray-400">for Everyday Use.</span></h1>
				<p class="text-2xl text-gray-500 mb-12 max-w-3xl mx-auto">
					SmartUp Tech develops lightweight, high-impact Android applications and enterprise solutions designed for daily efficiency and long-term reliability.
				</p>
				<div class="flex flex-wrap justify-center gap-4">
					<CTAButton href="/contact">Contact Us</CTAButton>
					<CTAButton href="/apps" variant="secondary">Explore Apps</CTAButton>
				</div>
			</div>
		</section>

		<!-- Our Story Section -->
		<section class="section-spacing bg-gray-50/50">
			<div class="max-w-[1400px] mx-auto px-6 md:px-12">
				<div class="grid md:grid-cols-2 gap-16 md:gap-32 items-center">
					<div>
						<h2 class="mb-8">Our Story</h2>
						<div class="space-y-6 text-xl text-gray-500 leading-relaxed">
							<p>
								SmartUp Tech was founded with a singular focus: solving real-world problems through purposeful software. We believe that technology should be a tool for empowerment, not a source of complexity.
							</p>
							<p>
								Our team specializes in high-quality mobile application development and modern website solutions. By combining technical rigor with a user-centric approach, we create digital products that stand the test of time.
							</p>
						</div>
					</div>
					<div class="aspect-square bg-white rounded-[4rem] shadow-xl border border-gray-100 flex items-center justify-center p-20">
						<img src="/smart-up-tech.webp" alt="SmartUp Tech Logo" class="w-full h-auto opacity-10 filter grayscale" />
					</div>
				</div>
			</div>
		</section>

		<!-- Expertise Section -->
		<section class="section-spacing">
			<div class="max-w-[1400px] mx-auto px-6 md:px-12">
				<div class="mb-24">
					<h2 class="mb-4">Our Expertise</h2>
					<p class="text-xl text-gray-500">Technical excellence across the full software stack.</p>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
					{expertise.map((item) => (
						<div class="p-12 rounded-[3rem] bg-gray-50/50 border border-transparent hover:border-gray-100 hover:bg-white transition-all group">
							<h3 class="text-2xl font-bold mb-4">{item.title}</h3>
							<p class="text-gray-500 leading-relaxed">{item.description}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- What We Value Section -->
		<section class="section-spacing bg-black text-white overflow-hidden">
			<div class="max-w-[1400px] mx-auto px-6 md:px-12">
				<div class="mb-24 text-center md:text-left">
					<h2 class="text-white mb-4">What We Value</h2>
					<p class="text-xl text-gray-400">The principles that guide our engineering and design.</p>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
					{values.map((value) => (
						<div class="p-12 rounded-[3rem] border border-white/10 bg-white/5 backdrop-blur-sm">
							<h3 class="text-2xl font-bold mb-4 text-white">{value.title}</h3>
							<p class="text-gray-400 text-lg leading-relaxed">{value.description}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- App Portfolio Highlight -->
		<section class="section-spacing">
			<div class="max-w-[1400px] mx-auto px-6 md:px-12">
				<div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-8">
					<div>
						<h2 class="mb-4">Android Portfolio</h2>
						<p class="text-xl text-gray-500">Serving millions of moments through specialized tools.</p>
					</div>
					<a href="/apps" class="font-bold text-lg hover:underline underline-offset-8">Explore All Apps &rarr;</a>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-6">
					{apps.map(app => (
						<a href={`/apps/${app.id}`} class="group p-8 rounded-[2.5rem] bg-gray-50/50 hover:bg-white border border-transparent hover:border-gray-100 transition-all shadow-sm hover:shadow-xl text-center">
							<img src={app.icon} alt={app.name} class="w-20 h-20 rounded-3xl mx-auto mb-6 shadow-md transition-transform group-hover:scale-110" />
							<h4 class="text-lg font-bold mb-2">{app.name}</h4>
							<p class="text-xs text-gray-500 line-clamp-2">{app.shortDescription}</p>
						</a>
					))}
				</div>
			</div>
		</section>

		<!-- Final CTA -->
		<section class="py-32 bg-gray-50/30">
			<div class="max-w-[800px] mx-auto px-6 text-center">
				<h2 class="mb-8">Let's build something <br />meaningful together.</h2>
				<p class="text-xl text-gray-500 mb-12">
					Whether you have a project in mind or want to learn more about our Android utilities, we're ready to connect.
				</p>
				<div class="flex flex-wrap justify-center gap-4">
					<CTAButton href="/contact">Get in Touch</CTAButton>
					<CTAButton href="/apps" variant="secondary">Browse Our Work</CTAButton>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
