---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import CTAButton from '../components/CTAButton.astro';
import { apps } from '../data/apps';

const expertise = [
	{
		title: "Mobile Development",
		description: "Expertise in building high-performance, native Android experiences that feel fluid and intuitive."
	},
	{
		title: "Utility Focus",
		description: "We focus on solving specific, everyday problems with tools that are efficient and easy to use."
	},
	{
		title: "Cultural Heritage",
		description: "Preserving and promoting cultural knowledge through specialized calendar and spiritual applications."
	},
	{
		title: "Data Precision",
		description: "Rigorous attention to detail in mathematical and astronomical calculations for absolute accuracy."
	},
	{
		title: "Performance Optimization",
		description: "Building lightweight apps that respect system resources and work flawlessly across all device types."
	},
	{
		title: "User-Centric Design",
		description: "Prioritizing clarity and accessibility to ensure our tools are useful for everyone, everywhere."
	}
];

const values = [
	{
		title: "Simplicity",
		description: "We believe the best tools are the ones you don't have to learn. We strive for zero-friction user interfaces."
	},
	{
		title: "Privacy",
		description: "Your data belongs to you. We design our applications to function locally and minimize data collection."
	},
	{
		title: "Reliability",
		description: "Software should be a dependable part of your day. We prioritize stability and long-term maintenance."
	},
	{
		title: "Authenticity",
		description: "We build products we use ourselves, with a commitment to quality and honest communication."
	}
];
---

<Layout title="About SmartUp Tech | Android App Publisher">
	<SEO
		slot="head"
		title="About SmartUp Tech | Android App Publisher"
		description="Learn about SmartUp Tech, our passion for building reliable Android applications and our commitment to quality mobile experiences."
	/>
	<Navbar />

	<main class="pt-20">
		<!-- Hero Section -->
		<section class="section-spacing">
			<div class="max-w-[1000px] mx-auto px-6 text-center">
				<h1 class="mb-8">Building Better Tools <br /><span class="text-gray-400">for Android.</span></h1>
				<p class="text-2xl text-gray-500 mb-12 max-w-3xl mx-auto">
					SmartUp Tech is an independent app publisher dedicated to creating useful, reliable, and beautifully designed Android applications for users worldwide.
				</p>
				<div class="flex flex-wrap justify-center gap-4">
					<CTAButton href="/apps">Explore Our Apps</CTAButton>
					<CTAButton href="/contact" variant="secondary">Get in Touch</CTAButton>
				</div>
			</div>
		</section>

		<!-- Our Mission Section -->
		<section class="section-spacing bg-gray-50/50">
			<div class="max-w-[1400px] mx-auto px-6 md:px-12">
				<div class="grid md:grid-cols-2 gap-16 md:gap-32 items-center">
					<div>
						<h2 class="mb-8">Our Mission</h2>
						<div class="space-y-6 text-xl text-gray-500 leading-relaxed">
							<p>
								At SmartUp Tech, we believe that the most powerful technology is the kind that helps you in your daily life without getting in your way.
							</p>
							<p>
								Since our founding, we have been focused on a single goal: publishing high-quality Android applications that serve a clear purpose. Whether it's tracking spiritual cycles, performing precise conversions, or managing business math, we build tools that users can trust.
							</p>
							<p>
								Our commitment is to long-term maintenance and continuous improvement. We don't just launch apps; we grow them alongside our community of users.
							</p>
						</div>
					</div>
					<div class="aspect-square bg-white rounded-[4rem] shadow-xl border border-gray-100 flex items-center justify-center p-20">
						<img src="/smart-up-tech.webp" alt="SmartUp Tech Logo" class="w-full h-auto opacity-10 filter grayscale" />
					</div>
				</div>
			</div>
		</section>

		<!-- Expertise Section -->
		<section class="section-spacing">
			<div class="max-w-[1400px] mx-auto px-6 md:px-12">
				<div class="mb-24">
					<h2 class="mb-4">Our Focus</h2>
					<p class="text-xl text-gray-500">Bringing technical excellence to every screen.</p>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
					{expertise.map((item) => (
						<div class="p-12 rounded-[3rem] bg-gray-50/50 border border-transparent hover:border-gray-100 hover:bg-white transition-all group">
							<h3 class="text-2xl font-bold mb-4">{item.title}</h3>
							<p class="text-gray-500 leading-relaxed">{item.description}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- What We Value Section -->
		<section class="section-spacing bg-black text-white overflow-hidden">
			<div class="max-w-[1400px] mx-auto px-6 md:px-12">
				<div class="mb-24 text-center md:text-left">
					<h2 class="text-white mb-4">What We Value</h2>
					<p class="text-xl text-gray-400">The principles that guide our product development.</p>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
					{values.map((value) => (
						<div class="p-12 rounded-[3rem] border border-white/10 bg-white/5 backdrop-blur-sm">
							<h3 class="text-2xl font-bold mb-4 text-white">{value.title}</h3>
							<p class="text-gray-400 text-lg leading-relaxed">{value.description}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- App Portfolio Highlight -->
		<section class="section-spacing">
			<div class="max-w-[1400px] mx-auto px-6 md:px-12">
				<div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-8">
					<div>
						<h2 class="mb-4">Android Portfolio</h2>
						<p class="text-xl text-gray-500">A collection of tools designed for millions of users.</p>
					</div>
					<a href="/apps" class="font-bold text-lg hover:underline underline-offset-8">View Full Portfolio &rarr;</a>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-6">
					{apps.map(app => (
						<a href={`/apps/${app.id}`} class="group p-8 rounded-[2.5rem] bg-gray-50/50 hover:bg-white border border-transparent hover:border-gray-100 transition-all shadow-sm hover:shadow-xl text-center">
							<img src={app.icon} alt={app.name} class="w-20 h-20 rounded-3xl mx-auto mb-6 shadow-md transition-transform group-hover:scale-110" />
							<h4 class="text-lg font-bold mb-2">{app.name}</h4>
							<p class="text-xs text-gray-500 line-clamp-2">{app.shortDescription}</p>
						</a>
					))}
				</div>
			</div>
		</section>

		<!-- Final CTA -->
		<section class="py-32 bg-gray-50/30">
			<div class="max-w-[800px] mx-auto px-6 text-center">
				<h2 class="mb-8">Discover our work <br />on Google Play.</h2>
				<p class="text-xl text-gray-500 mb-12">
					We invite you to explore our applications and see how we are making a difference in the daily lives of millions of users.
				</p>
				<div class="flex flex-wrap justify-center gap-4">
					<CTAButton href="https://play.google.com/store/apps/dev?id=6614685995890456247" target="_blank">Google Play Profile</CTAButton>
					<CTAButton href="/apps" variant="secondary">Browse All Apps</CTAButton>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
