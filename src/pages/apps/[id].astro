---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import SEO from '../../components/SEO.astro';
import ScreenshotGallery from '../../components/ScreenshotGallery.astro';
import FAQ from '../../components/FAQ.astro';
import RelatedApps from '../../components/RelatedApps.astro';
import { apps } from '../../data/apps';

export async function getStaticPaths() {
	return apps.map((app) => ({
		params: { id: app.id },
		props: { app },
	}));
}

const { app } = Astro.props;
---

<Layout title={app.name}>
	<SEO slot="head" app={app} />
	<Navbar />

	<main class="pt-20">
		<!-- Hero Section -->
		<section class="py-24 md:py-32">
			<div class="max-w-[1400px] mx-auto px-6 md:px-12">
				<div class="flex flex-col md:flex-row items-center gap-16">
					<div class="flex-1 space-y-8 text-center md:text-left">
						<img
							src={app.icon}
							alt={`${app.name} - ${app.tagline}`}
							class="w-32 h-32 md:w-40 md:h-40 rounded-[2.5rem] shadow-2xl mx-auto md:mx-0 object-cover"
							style={`border: 1px solid ${app.themeColor}20`}
						/>

						<div class="space-y-4">
							<span class="text-sm font-bold tracking-[0.2em] uppercase" style={`color: ${app.themeColor}`}>
								{app.category}
							</span>
							<h1 class="text-5xl md:text-8xl">{app.name}</h1>
							<p class="text-2xl md:text-3xl font-medium" style={`color: ${app.themeColor}`}>
								{app.tagline}
							</p>
						</div>

						<p class="text-xl text-gray-500 max-w-2xl leading-relaxed">
							{app.longDescription}
						</p>

						<div class="flex flex-wrap items-center justify-center md:justify-start gap-4 pt-4">
							<a
								href={app.playStoreUrl}
								target="_blank"
								class="bg-black text-white px-10 py-5 rounded-full font-bold text-lg hover:bg-gray-800 transition-all hover:-translate-y-1 shadow-xl flex items-center gap-3"
							>
								Download on Play Store
								<svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor">
									<path d="M3,20.5V3.5C3,2.91 3.34,2.39 3.84,2.15L13.69,12L3.84,21.85C3.34,21.61 3,21.09 3,20.5M16.81,15.12L18.66,14.05C21.08,12.65 21.08,11.35 18.66,9.95L16.81,8.88L14.4,11.29L16.81,15.12M4.6,2.09L13.97,11.46L16.08,9.35L4.87,2.92C4.78,2.87 4.69,2.83 4.6,2.79C4.46,2.74 4.34,2.71 4.24,2.71C4.06,2.71 3.94,2.8 3.94,3C3.94,3 4.22,2.47 4.6,2.09M3.94,21C3.94,21.2 4.06,21.29 4.24,21.29C4.34,21.29 4.46,21.26 4.6,21.21C4.69,21.17 4.78,21.13 4.87,21.08L16.08,14.65L13.97,12.54L4.6,21.91C4.22,21.53 3.94,21 3.94,21Z" />
								</svg>
							</a>
							<a
								href="/apps"
								class="px-10 py-5 rounded-full font-bold text-lg border border-gray-200 hover:border-black transition-all"
							>
								View All Apps
							</a>
						</div>
					</div>

					<div class="hidden lg:block flex-1">
						<!-- Decorative element or app visual -->
						<div
							class="w-full aspect-square rounded-[4rem] flex items-center justify-center relative overflow-hidden"
							style={`background: linear-gradient(135deg, ${app.themeColor}10 0%, ${app.themeColor}20 100%)`}
						>
							<img
								src={app.icon}
								alt={`${app.name} - ${app.tagline}`}
								class="w-1/2 h-1/2 rounded-[2.5rem] shadow-2xl transition-transform duration-700 hover:scale-110 object-cover"
							/>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Screenshots Section -->
		<section class="section-spacing bg-gray-50/30">
			<div class="max-w-[1400px] mx-auto px-6 md:px-12">
				<div class="mb-16 text-center md:text-left">
					<h2 class="mb-4">Experience {app.name}.</h2>
					<p class="text-xl text-gray-500">Take a look at the clean, intuitive interface designed for efficiency.</p>
				</div>
				<ScreenshotGallery app={app} />
			</div>
		</section>

		<!-- Features Section -->
		<section class="section-spacing">
			<div class="max-w-[1400px] mx-auto px-6 md:px-12">
				<div class="mb-16 text-center">
					<h2 class="mb-4">Everything you need.</h2>
					<p class="text-xl text-gray-500">Powerful features wrapped in a simple experience.</p>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
					{app.features.map((feature) => (
						<div class="p-10 rounded-[2.5rem] bg-gray-50/50 hover:bg-white border border-transparent hover:border-gray-100 transition-all shadow-sm hover:shadow-xl group">
							<div
								class="w-12 h-12 rounded-2xl flex items-center justify-center mb-6 transition-transform group-hover:scale-110"
								style={`background-color: ${app.themeColor}15; color: ${app.themeColor}`}
							>
								<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
							</div>
							<h3 class="text-xl font-bold mb-3">{feature}</h3>
							<p class="text-gray-500 text-sm">Optimized for accuracy and speed, ensuring you get the best experience every time.</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Benefits Section -->
		<section class="section-spacing bg-black text-white overflow-hidden">
			<div class="max-w-[1400px] mx-auto px-6 md:px-12">
				<div class="grid md:grid-cols-2 gap-24 items-center">
					<div>
						<h2 class="text-white mb-12">Why choose <br />{app.name}?</h2>
						<ul class="space-y-10">
							{app.benefits.map((benefit) => (
								<li class="flex gap-6">
									<div
										class="flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center mt-1"
										style={`background-color: ${app.themeColor}`}
									>
										<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 5 5L20 7"/></svg>
									</div>
									<p class="text-xl text-gray-400 leading-relaxed">{benefit}</p>
								</li>
							))}
						</ul>
					</div>
					<div class="relative">
						<div
							class="absolute -inset-24 blur-[120px] opacity-20 rounded-full"
							style={`background-color: ${app.themeColor}`}
						></div>
						<div class="relative aspect-square rounded-[4rem] border border-white/10 bg-white/5 backdrop-blur-3xl flex items-center justify-center">
							<div class="text-center p-12">
								<p class="text-6xl font-bold mb-4">4.5★</p>
								<p class="text-gray-400 uppercase tracking-widest text-sm">Average Rating</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- FAQ Section -->
		<section class="section-spacing">
			<div class="max-w-[1400px] mx-auto px-6 md:px-12">
				<div class="mb-24 text-center">
					<h2 class="mb-4">Common Questions.</h2>
					<p class="text-xl text-gray-500">Everything you need to know about {app.name}.</p>
				</div>
				<FAQ faqs={app.faqs} />
			</div>
		</section>

		<!-- Download CTA -->
		<section class="py-32">
			<div class="max-w-[1000px] mx-auto px-6 text-center">
				<div
					class="p-16 md:p-24 rounded-[4rem] relative overflow-hidden group"
					style={`background-color: ${app.themeColor}10`}
				>
					<div class="relative z-10">
						<h2 class="mb-8">Ready to get started?</h2>
						<p class="text-xl text-gray-500 mb-12 max-w-xl mx-auto">
							Join millions of users who rely on {app.name} for their daily {app.category.toLowerCase()} needs.
						</p>
						<a
							href={app.playStoreUrl}
							target="_blank"
							class="inline-flex items-center gap-3 bg-black text-white px-12 py-6 rounded-full font-bold text-xl hover:bg-gray-800 transition-all hover:-translate-y-1 shadow-2xl"
						>
							Download for Android
							<svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor">
								<path d="M3,20.5V3.5C3,2.91 3.34,2.39 3.84,2.15L13.69,12L3.84,21.85C3.34,21.61 3,21.09 3,20.5M16.81,15.12L18.66,14.05C21.08,12.65 21.08,11.35 18.66,9.95L16.81,8.88L14.4,11.29L16.81,15.12M4.6,2.09L13.97,11.46L16.08,9.35L4.87,2.92C4.78,2.87 4.69,2.83 4.6,2.79C4.46,2.74 4.34,2.71 4.24,2.71C4.06,2.71 3.94,2.8 3.94,3C3.94,3 4.22,2.47 4.6,2.09M3.94,21C3.94,21.2 4.06,21.29 4.24,21.29C4.34,21.29 4.46,21.26 4.6,21.21C4.69,21.17 4.78,21.13 4.87,21.08L16.08,14.65L13.97,12.54L4.6,21.91C4.22,21.53 3.94,21 3.94,21Z" />
							</svg>
						</a>
					</div>
					<div
						class="absolute top-0 right-0 w-64 h-64 blur-[100px] opacity-20 -mr-32 -mt-32 transition-transform duration-1000 group-hover:scale-150"
						style={`background-color: ${app.themeColor}`}
					></div>
				</div>
			</div>
		</section>

		<!-- Related Apps -->
		<section class="section-spacing border-t border-gray-100">
			<div class="max-w-[1400px] mx-auto px-6 md:px-12">
				<div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-8">
					<div class="text-center md:text-left">
						<h2 class="mb-4">Explore more apps.</h2>
						<p class="text-xl text-gray-500">Discover other high-quality tools from SmartUp Tech.</p>
					</div>
					<a href="/apps" class="font-bold text-lg hover:underline underline-offset-8">View all products &rarr;</a>
				</div>
				<RelatedApps currentId={app.id} />
			</div>
		</section>
	</main>

	<Footer />
</Layout>
